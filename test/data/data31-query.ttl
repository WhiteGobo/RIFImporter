@prefix rif: <http://www.w3.org/2007/rif#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

[] a rif:Subclass ;
    rif:sub [ a rif:Const ;
            rif:constIRI "http://example.org/example#C"^^xsd:anyURI ] ;
    rif:super [ a rif:Const ;
            rif:constIRI "http://example.org/example#D"^^xsd:anyURI ] .
