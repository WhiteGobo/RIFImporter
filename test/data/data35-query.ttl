@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rif: <http://www.w3.org/2007/rif#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

[] a rif:Atom ;
	rif:args ( [ a rif:Const ;
		    rif:value 1 ] [ a rif:Const ;
		    rif:value 2 ] [ a rif:Const ;
		    rif:value 3 ] ) ;
	rif:op [ a rif:Const ;
		rif:constIRI "http://example.org/example#a"^^xsd:anyURI ] .
[] a rif:Frame ;
	rif:object [ a rif:Const ;
		rif:constIRI "http://example.org/example#b"^^xsd:anyURI ] ;
	rif:slots ( [ a rif:Slot ;
		    rif:slotkey [ a rif:Const ;
			    rif:constIRI "http://example.org/example#p"^^xsd:anyURI ] ;
		    rif:slotvalue [ a rif:Const ;
			    rif:value "a string"^^xsd:string ] ] ) .
[] a rif:Member ;
	rif:class [ a rif:Const ;
		rif:constIRI "http://example.org/example#A"^^xsd:anyURI ] ;
	rif:instance [ a rif:Const ;
		rif:constIRI "http://example.org/example#b"^^xsd:anyURI ] .
[] a rif:Subclass ;
	rif:sub [ a rif:Const ;
		rif:constIRI "http://example.org/example#A"^^xsd:anyURI ] ;
	rif:super [ a rif:Const ;
		rif:constIRI "http://example.org/example#B"^^xsd:anyURI ] .
[] a rif:Equal ;
	rif:left [ a rif:Const ;
		rif:constIRI "http://example.org/example#a"^^xsd:anyURI ] ;
	rif:right [ a rif:Const ;
		rif:constIRI "http://example.org/example#b"^^xsd:anyURI ] .
